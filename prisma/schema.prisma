// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // Configuração de pool de conexões para arquivos grandes
  // Adicione à sua DATABASE_URL: ?schema=public&pool_size=50&statement_timeout=300000
}

// ============================================
// Tabelas de Domínio (Lookup Tables)
// ============================================

model NaturaJuridica {
  id         Int         @id @default(autoincrement())
  codigo     Int         @unique
  descricao  String
  empresas   Empresa[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt @default(now())

  @@map("natureza_juridica")
}

model PorteEmpresa {
  id         Int         @id @default(autoincrement())
  codigo     Int         @unique
  descricao  String
  empresas   Empresa[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt @default(now())

  @@map("porte_empresa")
}

model Pais {
  id         Int              @id @default(autoincrement())
  codigo     Int              @unique
  descricao  String
  estabelecimentos Estabelecimento[]
  socios     Socio[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt @default(now())

  @@map("pais")
}

model Municipio {
  id         Int              @id @default(autoincrement())
  codigo     Int              @unique
  descricao  String
  estabelecimentos Estabelecimento[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt @default(now())

  @@map("municipio")
}

model Cnae {
  id         Int         @id @default(autoincrement())
  codigo     Int         @unique
  descricao  String
  estabelecimentos EstabelecimentoCnae[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt @default(now())

  @@map("cnae")
}

model SituacaoCadastral {
  id         Int              @id @default(autoincrement())
  codigo     Int              @unique
  descricao  String
  estabelecimentos Estabelecimento[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt @default(now())

  @@map("situacao_cadastral")
}

model MotivoSituacaoCadastral {
  id         Int              @id @default(autoincrement())
  codigo     Int              @unique
  descricao  String
  estabelecimentos Estabelecimento[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt @default(now())

  @@map("motivo_situacao_cadastral")
}

model IdentificadorMatrizFilial {
  id         Int              @id @default(autoincrement())
  codigo     Int              @unique
  descricao  String
  estabelecimentos Estabelecimento[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt @default(now())

  @@map("identificador_matriz_filial")
}

model QualificacaoSocio {
  id         Int        @id @default(autoincrement())
  codigo     Int        @unique
  descricao  String
  socios     Socio[]
  socios_representante Socio[] @relation("RepresentanteLegal")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt @default(now())

  @@map("qualificacao_socio")
}

model IdentificadorSocio {
  id         Int        @id @default(autoincrement())
  codigo     Int        @unique
  descricao  String
  socios     Socio[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt @default(now())

  @@map("identificador_socio")
}

// ============================================
// Tabelas Principais
// ============================================

model Empresa {
  id                      Int         @id @default(autoincrement())
  cnpjBasico              Int         @unique
  razaoSocial             String
  naturezaJuridica        NaturaJuridica @relation(fields: [naturezaJuridicaCodigo], references: [codigo])
  naturezaJuridicaCodigo  Int
  qualificacaoResponsavel String?
  capitalSocial           String?
  porteEmpresa            PorteEmpresa? @relation(fields: [porteEmpresaCodigo], references: [codigo])
  porteEmpresaCodigo      Int?
  enteFederativoResponsavel String?
  situacaoEspecial        String?
  dataSituacaoEspecial    DateTime?
  estabelecimentos        Estabelecimento[]
  dadosSimples            DadosSimples?
  socios                  Socio[]
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  @@map("empresa")
}

model Estabelecimento {
  id                        Int         @id @default(autoincrement())
  cnpjBasico                Int
  cnpjOrdem                 Int
  cnpjDv                    Int
  empresa                   Empresa     @relation(fields: [cnpjBasico], references: [cnpjBasico])
  identificadorMatrizFilial IdentificadorMatrizFilial @relation(fields: [identificadorMatrizFilialCodigo], references: [codigo])
  identificadorMatrizFilialCodigo Int
  nomeFantasia              String?
  situacaoCadastral         SituacaoCadastral @relation(fields: [situacaoCadastralCodigo], references: [codigo])
  situacaoCadastralCodigo   Int
  dataSituacaoCadastral     DateTime?
  motivoSituacaoCadastral   MotivoSituacaoCadastral? @relation(fields: [motivoSituacaoCadastralCodigo], references: [codigo])
  motivoSituacaoCadastralCodigo Int?
  nomeCidadeExterior        String?
  pais                      Pais?       @relation(fields: [paisCodigo], references: [codigo])
  paisCodigo                Int?
  dataInicioAtividade       DateTime?
  tipoLogradouro            String?
  cnaes                     EstabelecimentoCnae[]
  logradouro                String?
  numero                    String?
  complemento               String?
  bairro                    String?
  cep                       String?
  uf                        String?
  municipio                 Municipio?  @relation(fields: [municipioCodigo], references: [codigo])
  municipioCodigo           Int?
  dddPrimario               Int?
  telefonePrimario          String?
  dddSecundario             Int?
  telefoneSecundario        String?
  dddFax                    Int?
  fax                       String?
  email                     String?
  situacaoEspecial          String?
  dataSituacaoEspecial      DateTime?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt

  @@unique([cnpjBasico, cnpjOrdem, cnpjDv])
  @@map("estabelecimento")
}

model DadosSimples {
  id                    Int         @id @default(autoincrement())
  cnpjBasico            Int         @unique
  empresa               Empresa     @relation(fields: [cnpjBasico], references: [cnpjBasico], onDelete: Cascade)
  opcaoSimples          Boolean?
  dataOpcaoSimples      DateTime?
  dataExclusaoSimples   DateTime?
  opcaoMei              Boolean?
  dataOpcaoMei          DateTime?
  dataExclusaoMei       DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@map("dados_simples")
}

model Socio {
  id                          Int         @id @default(autoincrement())
  cnpjBasico                  Int
  empresa                     Empresa     @relation(fields: [cnpjBasico], references: [cnpjBasico])
  identificadorSocio          IdentificadorSocio @relation(fields: [identificadorSocioCodigo], references: [codigo])
  identificadorSocioCodigo    Int
  nomeSocio                   String
  cnpjCpfSocio                String?
  qualificacaoSocio           QualificacaoSocio @relation(fields: [qualificacaoSocioCodigo], references: [codigo])
  qualificacaoSocioCodigo     Int
  dataEntradaSociedade        DateTime?
  pais                        Pais?       @relation(fields: [paisCodigo], references: [codigo])
  paisCodigo                  Int?
  representanteLegalCpf       String?
  nomeRepresentanteLegal      String?
  qualificacaoRepresentanteLegal QualificacaoSocio? @relation("RepresentanteLegal", fields: [qualificacaoRepresentanteLegalCodigo], references: [codigo])
  qualificacaoRepresentanteLegalCodigo Int?
  faixaEtaria                 Int?
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  @@unique([cnpjBasico, cnpjCpfSocio])
  @@map("socio")
}

// ============================================
// Rastreamento de Importações
// ============================================

enum ImportacaoStatus {
  PENDENTE
  IMPORTANDO
  SUCESSO
  ERRO
}

model ImportacaoLog {
  id              Int              @id @default(autoincrement())
  arquivo         String
  pasta           String
  tabela          String
  status          ImportacaoStatus
  totalRegistros  Int?
  erroMensagem    String?
  iniciadoEm      DateTime         @default(now())
  finalizadoEm    DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([arquivo, pasta])
  @@map("importacao_log")
}

// ============================================
// Relação Estabelecimento <-> CNAE
// ============================================

model EstabelecimentoCnae {
  id                Int             @id @default(autoincrement())
  estabelecimento   Estabelecimento @relation(fields: [estabelecimentoId], references: [id], onDelete: Cascade)
  estabelecimentoId Int
  cnae              Cnae            @relation(fields: [cnaeCodigo], references: [codigo])
  cnaeCodigo        Int
  isPrincipal       Boolean         @default(false)
  createdAt         DateTime        @default(now())

  @@unique([estabelecimentoId, cnaeCodigo])
  @@map("estabelecimento_cnae")
}
