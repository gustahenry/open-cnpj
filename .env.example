# Database Configuration
# PostgreSQL
# Para importação de arquivos grandes, adicione os parâmetros:
# ?schema=public&pool_size=50&statement_timeout=300000
DATABASE_URL="postgresql://root:123456@localhost:5432/open_cnpj?schema=public&pool_size=50&statement_timeout=300000"
# SQLite (uncomment to use)
# DATABASE_URL="file:./dev.db"

# Server Configuration
PORT=3000
NODE_ENV=development

# Prisma Logging (opcional)
# Descomente para ativar logging detalhado do Prisma
# PRISMA_LOG=true
